# NOTE: This file is generated from pyproject.toml.in by CMake.
# Do not edit this file directly. Edit pyproject.toml.in instead.
#
# NumPy ABI: We build extensions against NumPy 2.x so a single wheel works with
# both NumPy 1.x and 2.x at runtime.
# See: numpy.org/devdocs/dev/depending_on_numpy.html

[build-system]
requires = ["setuptools>=64", "wheel", "numpy>=2.0"]
build-backend = "setuptools.build_meta"

[project]
name = "isaacteleop"
version = "@ISAAC_TELEOP_PYPROJECT_VERSION@"
description = "Isaac Teleop - Teleoperation with Device I/O"
readme = "README.md"
requires-python = ">=3.10"
license = "Apache-2.0"
authors = [
    {name = "NVIDIA"}
]
dynamic = ["dependencies", "optional-dependencies"]

[tool.setuptools.dynamic]
dependencies = {file = ["requirements.txt"]}
optional-dependencies.dev = {file = ["requirements-dev.txt"]}
optional-dependencies.ui = {file = ["requirements-ui.txt"]}
optional-dependencies.retargeters = {file = ["requirements-retargeters.txt"]}
optional-dependencies.retargeters-lite = {file = ["requirements-retargeters-lite.txt"]}
optional-dependencies.grounding = {file = ["requirements-grounding.txt"]}
optional-dependencies.cloudxr = {file = ["requirements-cloudxr.txt"]}

[tool.setuptools]
packages = [
    "isaacteleop",
    "isaacteleop.deviceio",
    "isaacteleop.deviceio_trackers",
    "isaacteleop.deviceio_session",
    "isaacteleop.mcap",
    "isaacteleop.oxr",
    "isaacteleop.plugin_manager",
    "isaacteleop.schema",
    "isaacteleop.retargeting_engine",
    "isaacteleop.retargeting_engine.interface",
    "isaacteleop.retargeting_engine.tensor_types",
    "isaacteleop.retargeting_engine.deviceio_source_nodes",
    "isaacteleop.retargeting_engine.utilities",
    "isaacteleop.retargeters",
    "isaacteleop.retargeters.G1",
    "isaacteleop.retargeting_engine_ui",
    "isaacteleop.teleop_session_manager",
    "isaacteleop.cloudxr",
@VIZ_PACKAGES_BLOCK@@ROBOTIC_GROUNDING_PACKAGES_BLOCK@]
include-package-data = false

[tool.setuptools.package-data]
isaacteleop = ["*.so", "*.pyd", "*.pyi", "py.typed"]
"isaacteleop.deviceio" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.deviceio_trackers" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.deviceio_session" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.mcap" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.oxr" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.plugin_manager" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.schema" = ["*.so", "*.pyd", "*.pyi"]
"isaacteleop.cloudxr" = ["native/*.so", "native/*.so.*", "native/openxr_cloudxr.json"]
@VIZ_PACKAGE_DATA_BLOCK@@ROBOTIC_GROUNDING_PACKAGE_DATA_BLOCK@

[tool.uv]
# Only use managed Python installations (not system Python)
python-preference = "only-managed"
